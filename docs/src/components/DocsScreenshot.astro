---
interface Props {
  alt: string;
  file: string;
}

const { alt, file } = Astro.props;
const basePath = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<figure class="docs-screenshot">
  <img src={`${basePath}screenshots/${file}`} alt={alt} loading="lazy" />
</figure>
