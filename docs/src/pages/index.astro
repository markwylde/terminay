---
// biome-ignore lint/correctness/noUnusedImports: Used in the Astro template below.
import Layout from '../layouts/Layout.astro';

const basePath = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

// biome-ignore lint/correctness/noUnusedVariables: Used in the Astro template below.
const heroScreenshot = {
  src: `${basePath}screenshots/terminay-hero-workspace.png`,
  alt: 'Terminay showing five project tabs and a two by two terminal workspace',
};

// biome-ignore lint/correctness/noUnusedVariables: Used in the Astro template below.
const featureScreenshots = [
  {
    src: `${basePath}screenshots/terminay-workspace.png`,
    alt: 'Terminay workspace showing project tabs, file explorer, and split terminal panes',
    title: 'Workspace',
    description: 'Organize projects with colored tabs, root folders, file explorer state, and docked terminal layouts.',
  },
  {
    src: `${basePath}screenshots/terminay-command-bar.png`,
    alt: 'Terminay Command bar searching project commands and macros',
    title: 'Command Bar',
    description: 'Search commands and macros from one keyboard-first launcher.',
  },
  {
    src: `${basePath}screenshots/terminay-macros.png`,
    alt: 'Terminay Macros window showing a macro library and execution steps',
    title: 'Macros',
    description: 'Build reusable terminal automations with steps, prompts, waits, clipboard paste, and secrets.',
  },
  {
    src: `${basePath}screenshots/terminay-files.png`,
    alt: 'Terminay file explorer and README preview beside terminal panes',
    title: 'Files',
    description: 'Open README files, previews, text buffers, diffs, PDFs, images, and folders beside terminals.',
  },
  {
    src: `${basePath}screenshots/terminay-folders.png`,
    alt: 'Terminay folder viewer showing gallery mode for a project folder',
    title: 'Folders',
    description: 'Browse folders as dockable tree, list, thumbnail, or gallery tabs.',
  },
  {
    src: `${basePath}screenshots/terminay-settings.png`,
    alt: 'Terminay Settings window showing searchable terminal appearance controls',
    title: 'Settings',
    description: 'Search settings, adjust the shell, tune appearance, and preview terminal changes.',
  },
  {
    src: `${basePath}screenshots/terminay-shortcuts.png`,
    alt: 'Terminay Settings window showing searchable keyboard shortcuts',
    title: 'Shortcuts',
    description: 'Capture, clear, reset, and inspect command shortcut conflicts.',
  },
  {
    src: `${basePath}screenshots/terminay-remote-access.png`,
    alt: 'Terminay Remote Access settings with pairing and TLS options',
    title: 'Remote Access',
    description: 'Pair a browser, manage trusted devices, and review live remote access state.',
  },
];

// biome-ignore lint/correctness/noUnusedVariables: Used in the Astro template below.
const features = [
  {
    title: 'Command Bar',
    description: 'Press Cmd/Ctrl+L to search terminal actions, workspace commands, file commands, and reusable macros without leaving the keyboard.',
  },
  {
    title: 'Project Workspaces',
    description: 'Give each project a root folder, file explorer state, color, and short icon so busy workspaces stay readable.',
  },
  {
    title: 'Macro Automation',
    description: 'Build multi-step macros with prompts, waits, clipboard paste, key presses, and encrypted secret insertion.',
  },
  {
    title: 'Settings That Travel',
    description: 'Tune shell behavior, themes, cursor style, shortcuts, scrolling, accessibility, and remote host options from one searchable settings window.',
  },
  {
    title: 'Files Beside Shells',
    description: 'Browse folders, open file and folder tabs, preview media and markdown, inspect Git diffs, and save edits next to terminals.',
  },
  {
    title: 'Remote Access',
    description: 'Pair a browser with a QR code, choose reachable addresses, and reach your sessions over the built-in HTTPS remote host.',
  },
];

// biome-ignore lint/correctness/noUnusedVariables: Used in the Astro template below.
const workflow = [
  'Open the Command bar',
  'Split a terminal or jump to a project',
  'Open files, folders, previews, or diffs',
  'Run a macro or pair remote access',
];
---

<Layout
  title="Terminay - A Terminal Workspace for Projects"
  description="Terminay is a desktop terminal workspace with dockable shells, file tools, macros, settings, colorful tabs, and browser-based remote access."
>
  <section class="hero">
    <div class="hero-content">
      <p class="eyebrow">Desktop terminal workspace</p>
      <h1 class="hero-title">Terminay</h1>
      <p class="hero-description">
        A focused terminal app for project work: native shells, dockable panes, file tools, macros, settings, colorful tabs, and remote access from a paired browser.
      </p>
      <div class="hero-cta">
        <a href="https://github.com/markwylde/terminay/releases" class="btn btn-primary">
          Download
        </a>
        <a href={`${basePath}docs`} class="btn btn-secondary">
          Read the docs
        </a>
      </div>
    </div>
    <figure class="screenshot-frame hero-screenshot">
      <img src={heroScreenshot.src} alt={heroScreenshot.alt} class="window-image" />
    </figure>
  </section>

  <section class="feature-band">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">What is new</p>
        <h2>More than a terminal grid</h2>
      </div>
      <div class="features-grid">
        {features.map((feature) => (
          <article class="feature-card">
            <h3>{feature.title}</h3>
            <p>{feature.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="screenshots-band">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">Screenshots</p>
        <h2>The main surfaces, captured from the app</h2>
      </div>
      <div class="screenshots-grid">
        {featureScreenshots.map((screenshot) => (
          <article class="screenshot-card">
            <figure class="screenshot-frame">
              <img src={screenshot.src} alt={screenshot.alt} class="window-image" loading="lazy" />
            </figure>
            <h3>{screenshot.title}</h3>
            <p>{screenshot.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="workflow-band">
    <div class="container workflow-layout">
      <div>
        <p class="eyebrow">Fast path</p>
        <h2>Keep the useful actions close</h2>
        <p>
          The Command bar brings app commands and macros into one searchable surface. It covers terminal splits, file explorer actions, project-root changes, save commands, and the repeated moves that happen all day in a terminal workspace.
        </p>
      </div>
      <ol class="workflow-list">
        {workflow.map((item) => <li>{item}</li>)}
      </ol>
    </div>
  </section>

  <section class="remote-band">
    <div class="container remote-layout">
      <div>
        <p class="eyebrow">Remote access</p>
        <h2>Pair a browser when the desktop is not enough</h2>
      </div>
      <p>
        Terminay can host an HTTPS remote endpoint, generate a pairing QR code, expose available local addresses, track paired devices, show live connections, and keep an audit trail in settings.
      </p>
    </div>
  </section>

  <section class="cta">
    <div class="container">
      <h2>Ready to try Terminay?</h2>
      <p>Download the latest release or build from source with the same scripts used by the automated docs screenshot workflow.</p>
      <div class="cta-buttons">
        <a href="https://github.com/markwylde/terminay/releases" class="btn btn-primary btn-large">
          Get Terminay
        </a>
        <a href="https://github.com/markwylde/terminay" class="btn btn-secondary btn-large" target="_blank" rel="noopener">
          View on GitHub
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .container {
    max-width: 1160px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .hero {
    position: relative;
    isolation: isolate;
    min-height: calc(100vh - 74px);
    padding: 5rem 2rem 3rem;
    display: grid;
    grid-template-columns: minmax(260px, 0.82fr) minmax(0, 1.18fr);
    gap: 3rem;
    align-items: center;
    max-width: 1320px;
    margin: 0 auto;
  }

  .hero::before {
    content: "";
    position: absolute;
    inset: 0;
    left: 50%;
    width: 100vw;
    transform: translateX(-50%);
    background: #202124;
    z-index: -1;
  }

  .eyebrow {
    color: #5eead4;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 0.7rem;
  }

  .hero-title {
    font-size: clamp(3rem, 8vw, 6.5rem);
    font-weight: 800;
    line-height: 0.95;
    margin-bottom: 1.25rem;
  }

  .hero-description {
    font-size: 1.08rem;
    color: var(--text-secondary);
    margin-bottom: 2rem;
    line-height: 1.7;
    max-width: 620px;
  }

  .hero-cta,
  .cta-buttons {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.82rem 1.25rem;
    border-radius: var(--radius-md);
    font-weight: 700;
    font-size: 0.98rem;
    transition: background 0.2s, border-color 0.2s, color 0.2s;
    border: 1px solid transparent;
  }

  .btn-primary {
    background: var(--accent-primary);
    color: #07110b;
  }

  .btn-primary:hover {
    background: var(--accent-secondary);
    opacity: 1;
  }

  .btn-secondary {
    background: transparent;
    border-color: var(--border-color);
    color: var(--text-primary);
  }

  .btn-secondary:hover {
    border-color: #5eead4;
    opacity: 1;
  }

  .btn-large {
    padding: 1rem 1.65rem;
    font-size: 1.05rem;
  }

  .hero-screenshot {
    margin: 0;
    width: 100%;
    box-shadow: 0 28px 80px rgba(0, 0, 0, 0.42);
  }

  .screenshot-frame {
    border: 1px solid #44484f;
    border-radius: 8px;
    overflow: hidden;
    background: #111315;
  }

  .window-image {
    width: 100%;
    display: block;
  }

  .feature-band,
  .remote-band {
    padding: 5.5rem 0;
    background: var(--bg-secondary);
  }

  .workflow-band {
    padding: 5.5rem 0;
  }

  .screenshots-band {
    padding: 5.5rem 0;
  }

  .section-heading {
    max-width: 620px;
    margin-bottom: 2rem;
  }

  h2 {
    font-size: clamp(2rem, 4vw, 3.2rem);
    line-height: 1.05;
    margin-bottom: 1rem;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .screenshots-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.5rem;
  }

  .feature-card {
    background: #2c2f33;
    border: 1px solid var(--border-color);
    border-radius: 8px;
    padding: 1.35rem;
  }

  .feature-card h3 {
    font-size: 1.05rem;
    margin-bottom: 0.6rem;
  }

  .screenshot-card h3 {
    font-size: 1.1rem;
    margin: 1rem 0 0.4rem;
  }

  .feature-card p,
  .screenshot-card p,
  .workflow-layout p,
  .remote-layout p,
  .cta p {
    color: var(--text-secondary);
    line-height: 1.7;
  }

  .workflow-layout,
  .remote-layout {
    display: grid;
    grid-template-columns: minmax(0, 0.85fr) minmax(0, 1fr);
    gap: 3rem;
    align-items: start;
  }

  .workflow-list {
    counter-reset: workflow;
    list-style: none;
    display: grid;
    gap: 0.8rem;
  }

  .workflow-list li {
    counter-increment: workflow;
    display: flex;
    align-items: center;
    gap: 1rem;
    background: #26292d;
    border: 1px solid var(--border-color);
    border-radius: 8px;
    padding: 1rem;
    color: var(--text-primary);
    font-weight: 650;
  }

  .workflow-list li::before {
    content: counter(workflow);
    width: 2rem;
    height: 2rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: #5eead4;
    color: #101414;
    font-family: var(--font-mono);
    font-weight: 700;
    flex: 0 0 auto;
  }

  .remote-layout {
    align-items: center;
  }

  .cta {
    padding: 5.5rem 2rem;
    text-align: center;
  }

  .cta .container {
    max-width: 760px;
  }

  .cta h2 {
    margin-bottom: 1rem;
  }

  .cta p {
    margin-bottom: 2rem;
  }

  .cta-buttons {
    justify-content: center;
  }

  @media (max-width: 940px) {
    .hero,
    .workflow-layout,
    .remote-layout {
      grid-template-columns: 1fr;
    }

    .hero {
      min-height: auto;
      padding-top: 4rem;
    }

    .features-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .screenshots-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .container,
    .hero {
      padding-left: 1rem;
      padding-right: 1rem;
    }

    .features-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
