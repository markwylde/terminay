{
  "name": "termide",
  "productName": "Termide",
  "private": true,
  "version": "0.0.0",
  "description": "A desktop terminal workspace built with Electron, React, and Vite.",
  "author": "Mark Wylde",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git@github.com:markwylde/termide.git"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:electron": "tsc && vite build && electron-builder --dir --mac --arm64 && open \"release/$npm_package_version/mac-arm64/Termide.app\"",
    "build:app": "tsc && vite build",
    "build": "npm run build:app && electron-builder --publish never",
    "build:mac": "npm run build:app && electron-builder --mac dmg --publish never",
    "build:linux": "npm run build:app && electron-builder --linux AppImage --publish never",
    "docs:screenshots": "npm run build:app && node scripts/generate-docs-screenshots.mjs",
    "docs:build": "npm run docs:screenshots && npm --prefix docs run build",
    "lint": "biome lint .",
    "smoke": "npm run lint && npm run build:app",
    "release": "node scripts/create-release.mjs",
    "test:e2e": "npm run build:app && playwright test",
    "test:e2e:headed": "npm run build:app && playwright test --headed",
    "test:release-config": "node --test scripts/release-config.test.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "dockview": "^5.2.0",
    "framer-motion": "^12.38.0",
    "jsqr": "^1.4.0",
    "lucide-react": "^1.8.0",
    "markdown-it": "^14.1.1",
    "monaco-editor": "^0.55.1",
    "node-pty": "^1.1.0",
    "pdfjs-dist": "^5.6.205",
    "qrcode": "^1.5.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "selfsigned": "^5.5.0",
    "ws": "^8.20.0"
  },
  "overrides": {
    "monaco-editor": {
      "dompurify": "3.4.1"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@playwright/test": "^1.59.1",
    "@types/markdown-it": "^14.1.2",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.9",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "main": "dist-electron/main.js"
}
