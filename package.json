{
  "name": "terminay",
  "productName": "Terminay",
  "private": true,
  "version": "0.0.0",
  "description": "A desktop terminal workspace built with Electron, React, and Vite.",
  "author": "Mark Wylde",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git@github.com:markwylde/terminay.git"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:electron": "tsc && vite build && electron-builder --dir --mac --arm64 && open \"release/$npm_package_version/mac-arm64/Terminay.app\"",
    "build:app": "tsc && vite build",
    "build": "npm run build:app && electron-builder --publish never",
    "build:mac": "npm run build:app && electron-builder --mac dmg --publish never",
    "build:linux": "npm run build:app && electron-builder --linux AppImage --publish never",
    "lint": "biome lint .",
    "smoke": "npm run lint && npm run build:app",
    "release": "node scripts/create-release.mjs",
    "test:e2e": "npm run build:app && playwright test",
    "test:e2e:ai-real": "playwright test e2e/ai-tab-metadata.spec.ts --grep @real-codex",
    "test:e2e:ai-real-claude": "playwright test e2e/ai-tab-metadata.spec.ts --grep @real-claude-code",
    "test:e2e:headed": "npm run build:app && playwright test --headed",
    "test:release-config": "node --test scripts/release-config.test.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "dockview": "^6.2.2",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.14.0",
    "markdown-it": "^14.1.1",
    "monaco-editor": "^0.55.1",
    "node-pty": "^1.1.0",
    "pdfjs-dist": "^5.7.284",
    "qrcode": "^1.5.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "selfsigned": "^5.5.0",
    "ws": "^8.20.1"
  },
  "overrides": {
    "monaco-editor": {
      "dompurify": "3.4.1"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@playwright/test": "^1.60.0",
    "@types/markdown-it": "^14.1.2",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.12",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.7"
  },
  "main": "dist-electron/main.js"
}
