{
  "name": "termide",
  "productName": "Termide",
  "private": true,
  "version": "0.0.0",
  "description": "A desktop terminal workspace built with Electron, React, and Vite.",
  "author": "Mark Wylde",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git@github.com:markwylde/termide.git"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:electron": "tsc && vite build && electron-builder --dir --mac --arm64 && open \"release/$npm_package_version/mac-arm64/Termide.app\"",
    "build:app": "tsc && vite build",
    "build": "npm run build:app && electron-builder --publish never",
    "build:mac": "npm run build:app && electron-builder --mac dmg --publish never",
    "build:linux": "npm run build:app && electron-builder --linux AppImage --publish never",
    "lint": "biome lint .",
    "smoke": "npm run lint && npm run build:app",
    "release": "node scripts/create-release.mjs",
    "test:release-config": "node --test scripts/release-config.test.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "@emoji-mart/data": "^1.2.1",
    "@emoji-mart/react": "^1.1.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "dockview": "^5.2.0",
    "framer-motion": "^12.38.0",
    "jsqr": "^1.4.0",
    "lucide-react": "^1.7.0",
    "node-pty": "^1.1.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "selfsigned": "^5.5.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.27.4",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "main": "dist-electron/main.js"
}
